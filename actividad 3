<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Filas combinadas</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-4">

  <!-- Fila 1: 2 columnas -->
  <div class="row">
    <div class="col bg-primary text-white p-3">1</div>
    <div class="col bg-success text-white p-3">2</div>
  </div>

  <!-- Fila 2: 3 columnas -->
  <div class="row mt-2">
    <div class="col bg-danger text-white p-3">1</div>
    <div class="col bg-warning text-dark p-3">2</div>
    <div class="col bg-info text-white p-3">3</div>
  </div>

  <!-- Fila 3: 2 columnas -->
  <div class="row mt-2">
    <div class="col bg-dark text-white p-3">1</div>
    <div class="col bg-secondary text-white p-3">2</div>
  </div>

</div>

</body>
</html>
